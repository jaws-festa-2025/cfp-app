{
  "availabilityZoneRebalancing": "DISABLED",
  "deploymentConfiguration": {
    "alarms": {
      "enable": false,
      "rollback": false,
      "alarmNames": []
    },
    "deploymentCircuitBreaker": {
      "enable": false,
      "rollback": false
    },
    "maximumPercent": 200,
    "minimumHealthyPercent": 50
  },
  "deploymentController": {
    "type": "ECS"
  },
  "desiredCount": 1,
  "enableECSManagedTags": false,
  "enableExecuteCommand": true,
  "healthCheckGracePeriodSeconds": 300,
  "launchType": "FARGATE",
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "assignPublicIp": "DISABLED",
      "securityGroups": [
        "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputServiceSecurityGroup` }}"
      ],
      "subnets": [
        "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputPrivateSubnet1` }}",
        "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputPrivateSubnet2` }}"
      ]
    }
  },
  "platformFamily": "Linux",
  "platformVersion": "LATEST",
  "propagateTags": "NONE",
  "schedulingStrategy": "REPLICA"
}
