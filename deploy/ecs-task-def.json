{
  "containerDefinitions": [
    {
      "cpu": 0,
      "dockerLabels": {},
      "environment": [
        {
          "name": "DATABASE_PORT",
          "value": "5432"
        },
        {
          "name": "DATABASE_HOST",
          "value": "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputDbClusterEndpoint` }}"
        },
        {
          "name": "DATABASE_NAME",
          "value": "cfp_app"
        },
        {
          "name": "RAILS_ENV",
          "value": "production"
        },
        {
          "name": "RAILS_LOG_TO_STDOUT",
          "value": "true"
        },
        {
          "name": "TIMEZONE",
          "value": "Asia/Tokyo"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "value": "sample"
        },
        {
          "name": "AWS_S3_BUCKET",
          "value": "sample"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "value": "sample"
        },
        {
          "name": "RAILS_SERVE_STATIC_FILES",
          "value": "true"
        },
        {
          "name": "MAIL_HOST",
          "value": "{{ cfn_output `CfpAppInfraStack` `CfpAppServiceDomain` }}"
        },
        {
          "name": "SMTP_ADDRESS",
          "value": "www5228.sakura.ne.jp"
        },
        {
          "name": "SMTP_DOMAIN",
          "value": "www5228.sakura.ne.jp"
        },
        {
          "name": "MAIL_FROM",
          "value": "jawsfesta2025-speakers@event.jaws-ug.jp"
        },
        {
          "name": "REDIS_URL",
          "value": "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputCacheEndpoint` }}"
        }
      ],
      "essential": true,
      "image": "122610521642.dkr.ecr.ap-northeast-1.amazonaws.com/cfp-app:{{ must_env `IMAGE_TAG` }}",
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/CfpApp",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "CfpApp"
        }
      },
      "name": "CfpAppContainer",
      "portMappings": [
        {
          "appProtocol": "",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_USERNAME",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/DbSecret` }}:username::"
        },
        {
          "name": "DATABASE_PASSWORD",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/DbSecret` }}:password::"
        },
        {
          "name": "SECRET_KEY_BASE",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/SecretKeyBase` }}:secretKeyBase::"
        },
        {
          "name": "SMTP_USERNAME",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/SmtpAuth` }}:username::"
        },
        {
          "name": "SMTP_PASSWORD",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/SmtpAuth` }}:password::"
        },
        {
          "name": "GITHUB_KEY",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/GitHubOAuth` }}:clientId::"
        },
        {
          "name": "GITHUB_SECRET",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/GitHubOAuth` }}:clientSecret::"
        },
        {
          "name": "SLACK_WEBHOOK_URL",
          "valueFrom": "{{ secretsmanager_arn `CfpApp/SlackWebhook` }}:webhookUrl::"
        }
      ],
      "versionConsistency": ""
    }
  ],
  "cpu": "256",
  "executionRoleArn": "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputExecutionRoleArn` }}",
  "family": "CfpAppTaskDef",
  "ipcMode": "",
  "memory": "1024",
  "networkMode": "awsvpc",
  "pidMode": "",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "taskRoleArn": "{{ cfn_output `CfpAppInfraStack` `CfpAppOutputTaskRoleArn` }}"
}
